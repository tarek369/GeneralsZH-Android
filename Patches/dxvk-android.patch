diff --git a/meson.build b/meson.build
index 26afed45..abeacd3d 100644
--- a/meson.build
+++ b/meson.build
@@ -10,10 +10,6 @@ cc = meson.get_compiler('c')
 dxvk_is_msvc = cpp.get_argument_syntax() == 'msvc'
 
 compiler_args = [
-  '-msse',
-  '-msse2',
-  '-msse3',
-  '-mfpmath=sse',
   '-Wimplicit-fallthrough',
   # gcc
   '-Wno-missing-field-initializers',
@@ -28,6 +24,16 @@ compiler_args = [
   '-Wno-missing-braces',
 ]
 
+# GeneralsX @build android-port 06/07/2026 Gate x86-only SSE flags behind x86.
+# Upstream applied -msse/-msse2/-msse3/-mfpmath=sse UNCONDITIONALLY in the
+# compiler_args array above; aarch64 clang (Android NDK, iOS) rejects
+# -mfpmath=sse with "the 'sse' unit is not supported with this instruction set".
+# DXVK's util_bit.h already has a __aarch64__ NEON branch, so the bitops are
+# ARM-ready — only the compiler flags were wrong.
+if cpu_family == 'x86' or cpu_family == 'x86_64'
+  compiler_args += ['-msse', '-msse2', '-msse3', '-mfpmath=sse']
+endif
+
 link_args = []
 
 if get_option('build_id')
diff --git a/src/wsi/sdl3/wsi_platform_sdl3.cpp b/src/wsi/sdl3/wsi_platform_sdl3.cpp
index 9975cdac..6c9309a9 100644
--- a/src/wsi/sdl3/wsi_platform_sdl3.cpp
+++ b/src/wsi/sdl3/wsi_platform_sdl3.cpp
@@ -15,6 +15,10 @@ namespace dxvk::wsi {
         "SDL3.dll"
 #elif defined(__APPLE__)
         "libSDL3.0.dylib"
+#elif defined(__ANDROID__)
+        // GeneralsX @build android-port 06/07/2026 Android packs the unversioned
+        // soname (libSDL3.so) in the APK; the ".so.0" Linux name does not exist.
+        "libSDL3.so"
 #else
         "libSDL3.so.0"
 #endif
